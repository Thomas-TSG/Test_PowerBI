		lineageTag: 4cb306eb-647e-48be-85a0-e3be12e2b3cf

	measure 'Penalty Residua' =
			
			SUMX(
			    lnd_offsetprogram,
			    VAR possible = lnd_offsetprogram[Possible Penalty]
			    VAR paid     = lnd_offsetprogram[Paid Penalties]
			    VAR diff     = possible - paid
			    RETURN
			        IF(
			            ISBLANK(possible) && ISBLANK(paid),
			            BLANK(),
			            DIVIDE(diff, lnd_offsetprogram[Exchange Rate])
			        )
			)
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Programme/Contract
		lineageTag: 0c8ccda7-18eb-4d5d-a171-45fdd3a4f6d5

