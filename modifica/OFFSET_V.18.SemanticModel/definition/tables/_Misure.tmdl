	measure 'Costo Offset vs Contratto Principale %' =
			
			VAR actualCostEUR =
			    SUMX(
			        lnd_offsetprogram,
			        DIVIDE(lnd_offsetprogram[Actual Cost], lnd_offsetprogram[Exchange Rate])
			    )
			RETURN
			DIVIDE(actualCostEUR, [Prime Contract Value], 0)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Programme/Contract
