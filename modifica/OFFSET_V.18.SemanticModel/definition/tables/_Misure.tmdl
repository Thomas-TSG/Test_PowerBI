	measure '% Penalties' =
			
			SELECTEDVALUE(lnd_offsetprogram[Penalty Percentage %])
		displayFolder: Programme/Contract
		lineageTag: 08f37d40-60d7-45b7-a3ca-10824c01405a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Liability totale' =
			
			SUMX(
			    lnd_offsetprogram,
			    VAR rate   = lnd_offsetprogram[Exchange Rate]
			    VAR offEUR = DIVIDE(lnd_offsetprogram[Offset Contract Value], rate)
			    VAR penPct = DIVIDE(lnd_offsetprogram[Penalty Percentage %], 100)
			    VAR penEUR = DIVIDE(lnd_offsetprogram[Offset Contract Value] * penPct, rate)
			    RETURN offEUR + penEUR
			)
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Programme/Contract
		lineageTag: 84277875-f9d3-4fcd-aa04-39868435b68b

	measure 'Liability Residual' = ```
			
			SUMX(
			    lnd_offsetprogram,
			    VAR penPct = DIVIDE(lnd_offsetprogram[Penalty Percentage %], 100)
			    VAR penLC  = lnd_offsetprogram[Offset Contract Value] * penPct
			    RETURN DIVIDE(penLC, lnd_offsetprogram[Exchange Rate])
			)
			
			```
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Programme/Contract
		lineageTag: b274fcd9-5277-480f-969b-022bf45a9b04

