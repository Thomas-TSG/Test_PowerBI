	measure 'Outstanding Obligation' = ```
			
			SUMX(
			    lnd_offsetprogram,
			    DIVIDE(lnd_offsetprogram[Outstanding Amount], lnd_offsetprogram[Exchange Rate])
			)
			
			```
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Programme/Contract
