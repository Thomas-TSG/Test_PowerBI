		annotation PBI_FormatHint = {"currencyCulture":"en-GB"}

	measure 'Expected Obligation (ANNO)' =
			
			VAR y = YEAR(TODAY())
			RETURN
			
			    CALCULATE (
			        [Expected Obligation],
			        KEEPFILTERS ( YEAR ( lnd_offsetprogram[Proposal Expiration Date] ) = y )
			    )
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Programme/Contract
		lineageTag: 183fcc2b-67ef-442a-874b-5a507d656915

	measure 'Offset Contract Value' =
			
			SUMX(
			    lnd_offsetprogram,
			    DIVIDE(lnd_offsetprogram[Offset Contract Value], lnd_offsetprogram[Exchange Rate])
			)
