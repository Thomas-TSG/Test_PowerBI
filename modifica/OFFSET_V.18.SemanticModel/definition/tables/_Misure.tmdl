			)
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Project
		lineageTag: 3d913a5a-e8d4-43ec-9d75-df7d3955ba45

	measure 'Quota Totale' =
			
			
			VAR pr = SELECTEDVALUE ( lnd_projects[Percentage of Progress] )
			VAR pr01 = IF ( pr > 1, pr / 100, pr )
			RETURN
			    CALCULATE ( DIVIDE ( [Quota Implementata Projects], pr01 ) )
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Budget
		lineageTag: 51cde0ea-8e1e-43d0-9b3c-c2ec2f02e94f

	measure 'Exchange Rate Program' =
			
			SELECTEDVALUE(lnd_offsetprogram[Exchange Rate])
		displayFolder: Programme/Contract
		lineageTag: 8d468190-55c5-4ec7-ab37-46d3657ad801

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Exchange Rate Project' = CALCULATE(SELECTEDVALUE(lnd_offsetprogram[Tasso di cambio]))
		displayFolder: Project
		lineageTag: e771036a-1bff-42c7-8a59-58885918c9c0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Future Milestone' =
			
			VAR _today = TODAY()
			RETURN
			CALCULATE(
			    SUMX(
			        lnd_milestone,
			        DIVIDE(
			            lnd_milestone[Target Amount],
			            lnd_milestone[Tasso di cambio]
			        )
			    ),
			    KEEPFILTERS(
			        FILTER(
			            lnd_milestone,
			            COALESCE(
			                lnd_milestone[Deferred Deadline],
			                lnd_milestone[Deadline]
			            ) >= _today
			        )
			    )
			)
		formatString: "£"#,0.###############;-"£"#,0.###############;"£"#,0.###############
		displayFolder: Milestone
		lineageTag: 28d2ed78-fb91-4415-aed8-03bf8d9908e7

		annotation PBI_FormatHint = {"currencyCulture":"en-GB"}

	measure 'Possible Penalties' =
			
			VAR _today = TODAY()
			RETURN
			CALCULATE(
			    SUMX(
			        lnd_offsetprogram,
			        DIVIDE(
			            lnd_offsetprogram[Possible Penalty],
			            lnd_offsetprogram[Tasso di cambio]
			        )
			    ),
			    KEEPFILTERS( lnd_offsetprogram[Amended End Date] >= _today )
			)
		formatString: "£"#,0.###############;-"£"#,0.###############;"£"#,0.###############
		displayFolder: Programme/Contract
		lineageTag: 479c0da7-13e4-4b02-a401-9e56c441a3fc

		annotation PBI_FormatHint = {"currencyCulture":"en-GB"}

	measure 'Storico - Outstanding Amount AsOf' = ```
			
			VAR AsOfDate = 
				MAX ('Calendar'[Date]) 
			
			/* 1) COMPONENTI OBBLIGATION AMOUNT */ 
			
			VAR OffsetContractValue_AsOf = 
			-- Valore fisso del contratto (non dipende dal tempo) 
				SUM (lnd_offsetprogram[Offset Contract Value]) 
			VAR AmendmentsAmount_AsOf = 
				CALCULATE ( 
				SUM (lnd_amendments[Difference Amount (base)]), 
				FILTER ( 
				ALL (lnd_amendments), 
				lnd_amendments[Date of Amendment] <= AsOfDate 
				) 
				) 
			VAR EscalationAmount_AsOf = 
			-- Serve tabella Penalties con data evento e escalated amount 
				CALCULATE ( 
				SUM ( lnd_penalties[lnd_escalatedamount]), 
				FILTER ( 
				ALL (lnd_penalties), 
				lnd_penalties[lnd_paymentdate] <= AsOfDate 
				) 
				) 
			VAR ObligationAmount_AsOf = 
				OffsetContractValue_AsOf 
				+ AmendmentsAmount_AsOf 
				+ EscalationAmount_AsOf
			
			/* 2) COMPONENTI DEDUTTIVE */ 
			VAR PerformedAmount_AsOf = 
				-- Performed = somma CreditAmount delle milestone 
				-- In pratica: somma degli Amount di Credit Utilization, filtrati per data credito <= AsOfDate 
				CALCULATE ( 
				SUM (lnd_creditutilization[Amount]), 
				FILTER ( 
				ALL (lnd_credits), 
				lnd_credits[Date of Credit] <= AsOfDate 
				) 
				) 
			VAR LiquidatedAmount_AsOf = 
				-- Serve tabella Penalties con data evento e liquidated amount 
				CALCULATE ( 
				SUM (lnd_penalties[lnd_liquidatedamount]), 
				FILTER ( 
				ALL (lnd_penalties), 
				lnd_penalties[lnd_paymentdate] <= AsOfDate 
				) 
				) 
			/* 3) OUTSTANDING */ 
			RETURN 
			ObligationAmount_AsOf 
			- PerformedAmount_AsOf 
			- LiquidatedAmount_AsOf
			
			```
		formatString: "£"#,0.###############;-"£"#,0.###############;"£"#,0.###############
		displayFolder: Storico
		lineageTag: 353245c7-c69c-4bef-ba47-ba5402239f5f

		annotation PBI_FormatHint = {"currencyCulture":"en-GB"}

	measure 'Difference Amendment Amount - solo BASE' =
			
			SUMX(
			    lnd_amendments,
			    DIVIDE(lnd_amendments[Difference Amount (base)], lnd_amendments[Tasso di cambio])
			)
		formatString: "£"#,0.###############;-"£"#,0.###############;"£"#,0.###############
		displayFolder: Amendments
		lineageTag: 8353a4cf-1fec-4750-8834-a0a466a5c16c

		annotation PBI_FormatHint = {"currencyCulture":"en-GB"}

	measure 'Escalated Amount' =
			
			SUMX( lnd_penalties,
			       DIVIDE( lnd_penalties[lnd_escalatedamount], lnd_penalties[exchangerate])
			 )
		formatString: "£"#,0.###############;-"£"#,0.###############;"£"#,0.###############
		displayFolder: Penalties
		lineageTag: 4e3ea79e-72fc-4c4d-b032-196351a98341

		annotation PBI_FormatHint = {"currencyCulture":"en-GB"}

	measure 'Credit Utilization Amount' = ```
			
			  SUMX (lnd_creditutilization,
			       DIVIDE( lnd_creditutilization[Amount], lnd_creditutilization[Tasso di cambio])
			  )
			```
		formatString: "£"#,0.###############;-"£"#,0.###############;"£"#,0.###############
		displayFolder: Credit Utilisation
		lineageTag: b66fc3c2-25c5-4300-ba72-e2bf8db765be

		annotation PBI_FormatHint = {"currencyCulture":"en-GB"}

	measure 'Liquidated Amount' =
			
			SUMX(lnd_penalties,
			    DIVIDE(lnd_penalties[lnd_liquidatedamount], lnd_penalties[exchangerate])
			)
		formatString: "£"#,0.###############;-"£"#,0.###############;"£"#,0.###############
		displayFolder: Penalties
		lineageTag: e285b71c-abbe-4241-b4bd-de8d32778835

		annotation PBI_FormatHint = {"currencyCulture":"en-GB"}

	measure 'Outstanding Amount AsOf (EUR) – Fino all’anno corrente' =
			
			VAR CurrYear = YEAR ( TODAY() )
			VAR Y =
			    SELECTEDVALUE ( 'Calendar'[Year] )
			VAR AsOfDate =
			    SWITCH (
			        TRUE(),
			        ISBLANK ( Y ), TODAY(),                  -- Totale / nessun anno in contesto
			        Y > CurrYear, BLANK(),                   -- Anni futuri: niente valori
			        Y = CurrYear, TODAY(),                   -- Anno corrente: oggi
			        DATE ( Y, 12, 31 )                       -- Anni passati: fine anno
			    )
			RETURN
			IF (
			    ISBLANK ( AsOfDate ),
			    BLANK(),
			    SUMX (
			        VALUES ( lnd_offsetprogram[Offset Program ID] ),
			
			        VAR OffsetContractValue_AsOf =
			            CALCULATE (
			                SUMX (
			                    lnd_offsetprogram,
			                    DIVIDE (
			                        lnd_offsetprogram[Offset Contract Value],
			                        lnd_offsetprogram[Exchange Rate]
			                    )
			                )
			            )
			
			        VAR AmendmentsAmount_AsOf =
			            CALCULATE (
			                SUMX (
			                    lnd_amendments,
			                    DIVIDE (
			                        lnd_amendments[Difference Amount (base)],
			                        lnd_amendments[Tasso di cambio]
			                    )
			                ),
			                FILTER (
			                    lnd_amendments,
			                    lnd_amendments[Date of Amendment] <= AsOfDate
			                )
			            )
			
			        VAR EscalationAmount_AsOf =
			            CALCULATE (
			                SUMX (
			                    lnd_penalties,
			                    DIVIDE (
			                        lnd_penalties[lnd_escalatedamount],
			                        lnd_penalties[exchangerate]
			                    )
			                ),
			                FILTER (
			                    lnd_penalties,
			                    lnd_penalties[lnd_paymentdate] <= AsOfDate
			                )
			            )
			
			        VAR PerformedAmount_AsOf =
			            CALCULATE (
			                SUMX (
			                    lnd_creditutilization,
			                    DIVIDE (
			                        lnd_creditutilization[Amount],
			                        lnd_creditutilization[Tasso di cambio]
			                    )
			                ),
			                FILTER (
			                    lnd_credits,
			                    lnd_credits[Date of Credit] <= AsOfDate
			                )
			            )
			
			        VAR LiquidatedAmount_AsOf =
			            CALCULATE (
			                SUMX (
			                    lnd_penalties,
			                    DIVIDE (
			                        lnd_penalties[lnd_liquidatedamount],
			                        lnd_penalties[exchangerate]
			                    )
			                ),
			                FILTER (
			                    lnd_penalties,
			                    lnd_penalties[lnd_paymentdate] <= AsOfDate
			                )
			            )
			
			        VAR ObligationAmount_AsOf =
			            OffsetContractValue_AsOf
			                + AmendmentsAmount_AsOf
			                + EscalationAmount_AsOf
			
			        RETURN
			            ObligationAmount_AsOf
			                - PerformedAmount_AsOf
			                - LiquidatedAmount_AsOf
			    )
			)
		formatString: "£"#,0.###############;-"£"#,0.###############;"£"#,0.###############
		displayFolder: Storico
		lineageTag: 4adbac3d-6c0b-428f-8170-84e504996cce

		annotation PBI_FormatHint = {"currencyCulture":"en-GB"}

