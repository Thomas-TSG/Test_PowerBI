			    CALCULATE(
			        SUM(lnd_milestone[Update Target Amount]),
			        FILTER(
			            lnd_milestone,
			                COALESCE(
			                    lnd_milestone[Deferred Deadline],
			                    lnd_milestone[Deadline]
			                ) = Y
			        )
			)
			
			```
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Milestone
		lineageTag: 3ce02d06-1b66-42df-b1c8-4bb84f97adbd

