	measure 'Obbligazione Soddisfatta%' =
			
			DIVIDE(
			    [Fulfilled Obligation (CORRETTA su Program)],
			    [Total Obligation Amount],
			    0
			) * 100
		formatString: 0.00%;-0.00%;0.00%
