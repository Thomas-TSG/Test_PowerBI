			    DIVIDE(lnd_projects[Project Value], lnd_projects[Tasso di cambio])
			)
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Project
		lineageTag: 7b2c5c10-0be2-485c-8b21-fef72aac55f6

	measure 'Quota Residua' =
			
