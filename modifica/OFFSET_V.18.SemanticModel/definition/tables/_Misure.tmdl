	measure 'Fulfilled Obligation (SBAGLIATO su Obligation Amount di Program)' = ```
			
			VAR Obl =
			    CALCULATE(SUM(lnd_offsetprogram[Obligation Amount]))
			VAR Out =
			    CALCULATE(SUM(lnd_offsetprogram[Outstanding Amount]))
			var OblExch = obl*[Exchange Rate Program]
			var OutExch = Out*[Exchange Rate Program]
			RETURN
			OblExch - OutExch
			
			```
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Budget
		lineageTag: 867fa2a6-3cb4-4ba8-ac9c-5e1aacfa9402

	measure 'Fulfilled Obligation (CORRETTA su Program)' =
			
			SUMX(
			    lnd_offsetprogram,
			    DIVIDE(
			        lnd_offsetprogram[Offset Contract Value] - lnd_offsetprogram[Outstanding Amount],
			        lnd_offsetprogram[Exchange Rate]
			    )
			)
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Programme/Contract
		lineageTag: a7f4f601-9b80-40df-a85c-c5993d1c6e9b

	measure 'Contractual Commitment 2025 (QUEST''ANNO)' = ```
			
